	(text "[util-button] On-board Control Buttons and Smart RESET"
		(exclude_from_sim no)
		(at 133.35 54.61 0)
		(effects
			(font
				(size 1.778 1.778)
				(thickness 0.4064)
				(bold yes)
				(color 72 72 72 1)
			)
		)
		(uuid "0f7c3ad3-ec73-4078-95d8-f41147904b08")
	)
	(text "* Usage of this IC is totally optional.\n  It can be left un-populated if not needed.\n* When ~{BTN} is pressed for at least 7.5s,\n  ~{RST} will be forced low. This can be used\n  to force a whole-board reset (including host)\n  without having to provide easy access to the\n  ~{RST} button (or to eliminate it altogether).\n* Keep ~{BTN} pressed for at least 8.5s and\n  the Power Path IC will also reset and\n  force the whole board to power-cycle."
		(exclude_from_sim no)
		(at 93.98 91.44 0)
		(effects
			(font
				(size 0.762 0.762)
				(color 72 72 72 1)
			)
			(justify left)
		)
		(uuid "b570c101-77cb-486b-961d-09a580b315cb")
	)
	(text "* Usage of this IC is optional, but recommended, as it allows for setting up the board for\n  programming with a single button (i.e., the RESET button). When RESET button is pressed\n  for at least 7.5s, BOOT line will be forced high, and will enable SoC boot from system\n  memory once ~{RST} is deasserted.\n* This same BOOT signal is passed to the host, such that programming can happen on all\n  sides (host and board). Of course, need or support for BOOT signal varies according to\n  the MCU. The capacitor and resistor on BOOT line are just assurances in case anything\n  goes wrong, or if the IC is deemed unnecessary."
		(exclude_from_sim no)
		(at 154.94 92.71 0)
		(effects
			(font
				(size 0.762 0.762)
				(color 72 72 72 1)
			)
			(justify left)
		)
		(uuid "fef5e212-7889-48e4-80fd-48a5baffdbf0")
	)
