		(uuid "1f27bea3-d6e5-4b1d-b761-0751e5a9b58b")
	)
	(text "[input-vbus] USB-C Connector: Protections, Filter and VUSB Discharge"
		(exclude_from_sim no)
		(at 106.68 29.21 0)
		(effects
			(font
				(size 2.032 2.032)
				(thickness 0.4064)
				(bold yes)
				(color 72 72 72 1)
			)
		)
		(uuid "45f209d5-6109-41c9-bf93-003785bddcae")
	)
	(text "* This cuts power for the TPD chip when USB-C is not connected.\n  The TPD*S300A needs to be powered together with the MCU\n  (the USB-PD controller), hence why an external power is\n  necessary, and why it's the same 3.3V from the MCU.\n* The board supports Source and Sink roles, including DRP. The\n  TPD will initially be powered, but considering its rather\n  high quiescent, it is a good idea to turn off the TPD\n  whenever the USB-PD role or MCU's mode of operation allows\n  for it.\n"
		(exclude_from_sim no)
		(at 127 105.41 0)
		(effects
			(font
				(size 0.762 0.762)
				(color 72 72 72 1)
			)
			(justify left)
		)
		(uuid "48bca6bd-deb1-43ea-92dd-47413c085bf6")
	)
	(text "* ESD protection and filtering.\n* Maybe it needs proper calculation for this Pi-like filter... Or perhaps it matters not."
		(exclude_from_sim no)
		(at 88.646 63.754 0)
		(effects
			(font
				(size 0.762 0.762)
				(color 72 72 72 1)
			)
			(justify left)
		)
		(uuid "651835ad-9c81-4667-9d51-5b67d594408d")
	)
	(text "* For impedance\n  matching, in case\n  it's necessary."
		(exclude_from_sim no)
		(at 88.9 85.09 0)
		(effects
			(font
				(size 0.762 0.762)
				(color 72 72 72 1)
			)
			(justify left)
		)
		(uuid "baf8bef3-2e20-4339-8cc6-97c742181b5f")
	)
