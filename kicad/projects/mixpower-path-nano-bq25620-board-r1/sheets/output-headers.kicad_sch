				(size 1.016 1.016)
				(color 132 132 132 1)
			)
		)
		(uuid "54d24503-c27b-4ef0-a00e-e823200769bd")
	)
	(text "5V"
		(exclude_from_sim no)
		(at 106.68 58.42 0)
		(effects
