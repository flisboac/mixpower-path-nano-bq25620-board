		(uuid "68da131a-96f9-47fd-9443-a37bae0b1824")
	)
	(text "* Considering L=(1uH * 0.7),\n  D=0.5:\n  - I_ripple = 3.571A\n  - I_charge = 3A\n  - I_saturation = 4.785 A"
		(exclude_from_sim no)
		(at 116.84 58.42 0)
		(effects
