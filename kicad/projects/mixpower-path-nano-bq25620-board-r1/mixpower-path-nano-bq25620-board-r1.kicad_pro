    "netclass_assignments": null,
    "netclass_patterns": [
      {
        "netclass": "Analog",
        "pattern": ")?(.*_)?(A(N?|NA?|DC?))\\d+\\"
      },
      {
        "netclass": "Analog_USB",
        "pattern": "(/.*/)?(.*_)?(D[pP]?|(SS)?(R|T)X[pP]?\\d?)(\\+|\\-|_P|_N)"
      },
      {
        "netclass": "Digital",
        "pattern": "(/.*/)?.*_?(SDA|SCL)(_TR)?"
      },
      {
        "netclass": "Digital",
        "pattern": "/?(.*/)?.*_?(RX(_?TX)?|TX(_?RX)?)\\d?(_TR)?"
      },
      {
        "netclass": "Digital",
        "pattern": "/?(.*/)?(.*_)?(MISO|MOSI|SDI|SDO|SD|WS)(_TR)?"
      },
      {
        "netclass": "Digital",
        "pattern": "/?(.*/)?(.*_)?(SCK|CLK|CLOCK|MCK)(_TR)?"
      },
      {
        "netclass": "Digital",
        "pattern": "/?(.*/)?(.*_)?DATA(_TR)?"
      },
      {
        "netclass": "Digital",
        "pattern": "/?(.*/)?(~\\{)?(.*_)?D(ATA_)?(IN?|O(UT)?|IO)?(_TR)?"
      },
      {
        "netclass": "Digital",
        "pattern": "/?(.*/)?(~\\{)?(.*_)?(SWCLK|SWDIO|TD(I|O)|T(MS|CK))(_TR)?"
      },
      {
        "netclass": "GPIO",
        "pattern": "/?(.*_)?(GP|P[A-Z]|B(T|TN)?)\\d+\\"
      },
      {
        "netclass": "GPIO",
        "pattern": "/?(.*_)?([nN](S|T))?(CE|INT|IRQ|EN|DIS|RST|FLT|FAULT|MODE|_ST|_SNS|_SENSE)(_.*)?\\"
      },
      {
        "netclass": "HighPwrLowVolt_5A_30V",
        "pattern": "/?(.*/)?V(BUS|EXT|AC1|AC2|SEL|OTG|SYS|SWN)\\d*(_.*(?<!_EN|_DIS|_FB|_PG|_FLT|_FAULT|_G|_P|_MODE|_ST|_SNS|_SENSE))?"
      },
      {
        "netclass": "LowPwrLowVolt_1A_30V",
        "pattern": "/?(.*/)?V(?!BUS|EXT|AC1|AC2|SEL|OTG|SYS|SWN)[a-zA-Z]+\\d*_?LP(_.*(?<!_EN|_DIS|_FB|_PG|_FLT|_FAULT|_G|_P|_MODE|_ST|_SNS|_SENSE))?"
      },
      {
        "netclass": "LowPwrLowVolt_1A_30V",
        "pattern": "/?(.*/)?\\d+V\\d*_?LP(_.*(?<!_EN|_DIS|_FB|_PG|_FLT|_FAULT|_G|_P|_MODE|_ST|_SNS|_SENSE))?"
      },
      {
        "netclass": "MidPwrLowVolt_3A_30V",
